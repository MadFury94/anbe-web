{
    "name": "anbe-api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "db:create": "wrangler d1 create anbe-db",
        "db:migrate": "wrangler d1 execute anbe-db --file=./migrations/0001_schema.sql",
        "db:seed": "wrangler d1 execute anbe-db --file=./migrations/0002_seed.sql",
        "db:migrate:remote": "wrangler d1 execute anbe-db --remote --file=./migrations/0001_schema.sql",
        "db:seed:remote": "wrangler d1 execute anbe-db --remote --file=./migrations/0002_seed.sql"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20241224.0",
        "typescript": "^5.6.2",
        "wrangler": "^3.95.0"
    }
}